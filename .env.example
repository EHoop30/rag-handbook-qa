# Copy to .env only if you want to change defaults. docker-compose reads it.
#
# Out of the box the service runs FULLY OFFLINE with no API keys: the "fake"
# providers do real bag-of-words retrieval and extractive answers, so you can
# clone, `docker compose up`, and hit /chat immediately. Switch to real models
# by setting the providers and keys below.

DATABASE_URL=postgresql://rag:rag@db:5432/rag

# --- Embeddings: "fake" (offline, no key) or "openai" (real retrieval) --------
EMBEDDING_PROVIDER=fake
# OPENAI_API_KEY=sk-...
# OPENAI_EMBEDDING_MODEL=text-embedding-3-small

# --- Answers: "fake" (offline extractive), "anthropic", or "openai" ----------
LLM_PROVIDER=fake
# ANTHROPIC_API_KEY=sk-ant-...
# ANTHROPIC_MODEL=claude-haiku-4-5-20251001

TOP_K=4
